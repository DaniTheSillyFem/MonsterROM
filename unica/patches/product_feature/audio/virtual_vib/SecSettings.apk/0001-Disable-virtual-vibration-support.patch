+++ b/smali_classes5/com/samsung/android/settings/asbase/audio/SoundSettings$3.smali
@@ -167,6 +167,14 @@
 
     invoke-virtual {v0, p1}, Ljava/util/ArrayList;->add(Ljava/lang/Object;)Z
 
+    move-object p1, p0
+
+    check-cast p1, Ljava/util/ArrayList;
+
+    const-string/jumbo v0, "vibration_sound_enabled"
+
+    invoke-virtual {p1, v0}, Ljava/util/ArrayList;->add(Ljava/lang/Object;)Z
+
     :cond_6
     invoke-static {}, Landroid/app/ActivityManager;->getCurrentUser()I
 
diff --git a/smali_classes5/com/samsung/android/settings/asbase/reset/ResetSoundSystemFeedbackSettings$1.smali b/smali_classes5/com/samsung/android/settings/asbase/reset/ResetSoundSystemFeedbackSettings$1.smali
