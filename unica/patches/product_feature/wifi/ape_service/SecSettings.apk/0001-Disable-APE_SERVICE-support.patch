+++ b/smali_classes2/com/samsung/android/settings/wifi/develop/ApePreferenceController.smali
@@ -4,9 +4,9 @@
 
 
 # static fields
-.field private static final SETTINGS_DEVELOPER_APE:Ljava/lang/String; = "sem_wifi_ape_enabled_labs"
+.field private static final SETTINGS_DEVELOPER_APE:Ljava/lang/String; = "sem_wifi_ape_enabled_unica"
 
-.field private static final SUPPORT_APE_SERVICE:Z = true
+.field private static final SUPPORT_APE_SERVICE:Z = false
 
 .field private static final TAG:Ljava/lang/String; = "ConfigureWifiSettings.Ape"
 
@@ -27,9 +27,9 @@
 
     move-result-object p0
 
