     invoke-static {p0, v0, v1}, Landroid/provider/Settings$Global;->putInt(Landroid/content/ContentResolver;Ljava/lang/String;I)Z
 
@@ -57,7 +57,7 @@
 .method public getAvailabilityStatus()I
     .locals 0
 
-    const/4 p0, 0x0
