 .../settings/wifi/develop/ApePreferenceController.smali       | 17 +++++++++--------
 1 file changed, 9 insertions(+), 8 deletions(-)

diff --git a/smali_classes2/com/samsung/android/settings/wifi/develop/ApePreferenceController.smali b/smali_classes2/com/samsung/android/settings/wifi/develop/ApePreferenceController.smali
index 265a02314..04b5e0f09 100644
