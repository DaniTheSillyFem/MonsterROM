From f34a5971f60e85abfada68ebfd24bcfe295cc804 Mon Sep 17 00:00:00 2001
From: Salvo Giangreco <giangrecosalvo9@gmail.com>
Date: Mon, 13 Oct 2025 22:01:18 +0200
Subject: [PATCH] Remove CUSTOM_BACKOFF value

---
 .../server/wifi/SemWifiCoexManager.smali      | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/smali/com/samsung/android/server/wifi/SemWifiCoexManager.smali b/smali/com/samsung/android/server/wifi/SemWifiCoexManager.smali
index 8cc1e4d..2e208b7 100644
--- a/smali/com/samsung/android/server/wifi/SemWifiCoexManager.smali
+++ b/smali/com/samsung/android/server/wifi/SemWifiCoexManager.smali
@@ -15,7 +15,7 @@
 
 .field public static final BAND_UNKNOWN:B = -0x1t
 
-.field public static final CUSTOM_BACKOFF_TYPE:Ljava/lang/String; = "CONFIG_CUSTOM_BACKOFF"
+.field public static final CUSTOM_BACKOFF_TYPE:Ljava/lang/String; = ""
 
 .field public static final DBG:Z
 
@@ -386,12 +386,12 @@
 
     if-eqz p2, :cond_0
 
-    const-string p2, "CUSTOM_BACKOFF_TYPE = CONFIG_CUSTOM_BACKOFF"
+    const-string p2, "CUSTOM_BACKOFF_TYPE = "
 
     invoke-static {v1, p2}, Landroid/util/Log;->d(Ljava/lang/String;Ljava/lang/String;)I
 
     :cond_0
-    const-string p2, "CONFIG_CUSTOM_BACKOFF"
+    const-string p2, ""
 
     invoke-static {p2}, Landroid/text/TextUtils;->isEmpty(Ljava/lang/CharSequence;)Z
 
-- 
