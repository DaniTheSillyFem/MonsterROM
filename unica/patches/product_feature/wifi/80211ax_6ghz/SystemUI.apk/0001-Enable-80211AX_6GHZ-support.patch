From 28bed68e3f8e1daba9da70ada01d3846d89f8127 Mon Sep 17 00:00:00 2001
From: Salvo Giangreco <giangrecosalvo9@gmail.com>
Date: Mon, 6 Oct 2025 21:10:44 +0200
Subject: [PATCH] Enable 80211AX_6GHZ support

---
 .../qs/tiles/detail/WifiDetailAdapter.smali   | 284 +++++++----
 .../AccessPointControllerImpl.smali           |  48 ++
 .../repository/prod/WifiRepositoryImpl.smali  | 178 ++++---
 .../android/wifitrackerlib/WifiEntry.smali    | 451 +++++++++---------
 4 files changed, 585 insertions(+), 376 deletions(-)

diff --git a/smali_classes4/com/android/wifitrackerlib/WifiEntry.smali b/smali_classes4/com/android/wifitrackerlib/WifiEntry.smali
--- a/smali_classes4/com/android/wifitrackerlib/WifiEntry.smali
+++ b/smali_classes4/com/android/wifitrackerlib/WifiEntry.smali
@@ -358,6 +358,60 @@
 .method public canSignIn()Z
     .locals 0
 
+    const/4 p0, 0x0
+
+    return p0
+.end method
+
+.method public final checkWifi6EStandard(II)Z
+    .locals 1
+
+    sget v0, Lcom/samsung/android/wifitrackerlib/SemWifiUtils;->$r8$clinit:I
+
+    const/16 v0, 0x1725
+
+    if-lt p1, v0, :cond_1
+
+    const/16 v0, 0x1bd5
+
+    if-gt p1, v0, :cond_1
+
+    const/4 p1, 0x6
+
+    if-lt p2, p1, :cond_0
+
+    const/4 p0, 0x1
+
+    return p0
+
+    :cond_0
+    new-instance p1, Ljava/lang/StringBuilder;
+
+    const-string v0, "invalid Wi-Fi 6E network "
+
+    invoke-direct {p1, v0}, Ljava/lang/StringBuilder;-><init>(Ljava/lang/String;)V
+
+    invoke-virtual {p0}, Lcom/android/wifitrackerlib/WifiEntry;->getKey()Ljava/lang/String;
+
+    move-result-object p0
+
+    invoke-virtual {p1, p0}, Ljava/lang/StringBuilder;->append(Ljava/lang/String;)Ljava/lang/StringBuilder;
+
+    const-string p0, " standard:"
+
+    invoke-virtual {p1, p0}, Ljava/lang/StringBuilder;->append(Ljava/lang/String;)Ljava/lang/StringBuilder;
+
+    invoke-virtual {p1, p2}, Ljava/lang/StringBuilder;->append(I)Ljava/lang/StringBuilder;
+
+    invoke-virtual {p1}, Ljava/lang/StringBuilder;->toString()Ljava/lang/String;
+
+    move-result-object p0
+
+    const-string p1, "WifiEntry."
+
+    invoke-static {p1, p0}, Landroid/util/Log;->e(Ljava/lang/String;Ljava/lang/String;)I
+
+    :cond_1
     const/4 p0, 0x0
 
     return p0
diff --git a/smali_classes3/com/android/systemui/statusbar/connectivity/AccessPointControllerImpl.smali b/smali_classes3/com/android/systemui/statusbar/connectivity/AccessPointControllerImpl.smali
--- a/smali_classes3/com/android/systemui/statusbar/connectivity/AccessPointControllerImpl.smali
+++ b/smali_classes3/com/android/systemui/statusbar/connectivity/AccessPointControllerImpl.smali
@@ -15,6 +15,8 @@
 
 .field public static final ICONS_WIFI6:[[I
 
+.field public static final ICONS_WIFI6E:[[I
+
 
 # instance fields
 .field public final mCallbacks:Ljava/util/ArrayList;
@@ -150,6 +152,52 @@
 
     sput-object v0, Lcom/android/systemui/statusbar/connectivity/AccessPointControllerImpl;->ICONS_WIFI6:[[I
 
+    const v0, 0x7f081148
+
+    const v1, 0x7f081139
+
+    filled-new-array {v0, v1}, [I
+
+    move-result-object v0
+
+    const v1, 0x7f081149
+
+    const v2, 0x7f08113a
+
+    filled-new-array {v1, v2}, [I
+
+    move-result-object v1
+
+    const v2, 0x7f08114a
+
+    const v3, 0x7f08113b
+
+    filled-new-array {v2, v3}, [I
+
+    move-result-object v2
+
+    const v3, 0x7f08114b
+
+    const v4, 0x7f08113c
+
+    filled-new-array {v3, v4}, [I
+
+    move-result-object v3
+
+    const v4, 0x7f08114c
+
+    const v5, 0x7f08113d
+
+    filled-new-array {v4, v5}, [I
+
+    move-result-object v4
+
+    filled-new-array {v0, v1, v2, v3, v4}, [[I
+
+    move-result-object v0
+
+    sput-object v0, Lcom/android/systemui/statusbar/connectivity/AccessPointControllerImpl;->ICONS_WIFI6E:[[I
+
     return-void
 .end method
 
