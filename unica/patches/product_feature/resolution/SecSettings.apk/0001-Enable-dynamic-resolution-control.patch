Date: Mon, 27 Apr 2026 22:39:56 +0200
Subject: [PATCH] Enable dynamic resolution control

---
 ...ScreenResolutionPreferenceController.smali | 19 ++++++++++++++++---
 ...reenResolutionSingleChoiceController.smali | 19 ++++++++++++++++---
 2 files changed, 32 insertions(+), 6 deletions(-)

diff --git a/smali_classes5/com/samsung/android/settings/display/controller/ScreenResolutionPreferenceController.smali b/smali_classes5/com/samsung/android/settings/display/controller/ScreenResolutionPreferenceController.smali
index 7f76106..e4bdcc8 100644
--- a/smali_classes5/com/samsung/android/settings/display/controller/ScreenResolutionPreferenceController.smali
+++ b/smali_classes5/com/samsung/android/settings/display/controller/ScreenResolutionPreferenceController.smali
@@ -155,11 +155,24 @@
 .end method
 
 .method public getAvailabilityStatus()I
-    .locals 0
+    .locals 1
 
-    sget-object p0, Lcom/samsung/android/settings/Rune;->COMMON_CONFIG_PACKAGE_NAME_SMART_MANAGER:Ljava/lang/String;
+    sget-object v0, Lcom/samsung/android/settings/Rune;->COMMON_CONFIG_PACKAGE_NAME_SMART_MANAGER:Ljava/lang/String;
+
+    iget-object p0, p0, Lcom/android/settingslib/core/AbstractPreferenceController;->mContext:Landroid/content/Context;
+
+    invoke-static {p0}, Lcom/android/settings/Utils;->isDesktopModeEnabled(Landroid/content/Context;)Z
+
+    move-result p0
 
-    const/4 p0, 0x3
+    if-eqz p0, :cond_0
+
+    const/4 p0, 0x5
+
+    return p0
+
+    :cond_0
+    const/4 p0, 0x0
 
     return p0
 .end method
diff --git a/smali_classes5/com/samsung/android/settings/display/controller/SecScreenResolutionSingleChoiceController.smali b/smali_classes5/com/samsung/android/settings/display/controller/SecScreenResolutionSingleChoiceController.smali
index f787f82..91e5b77 100644
--- a/smali_classes5/com/samsung/android/settings/display/controller/SecScreenResolutionSingleChoiceController.smali
+++ b/smali_classes5/com/samsung/android/settings/display/controller/SecScreenResolutionSingleChoiceController.smali
@@ -518,11 +518,24 @@
 .end method
 
 .method public getAvailabilityStatus()I
-    .locals 0
+    .locals 1
 
-    sget-object p0, Lcom/samsung/android/settings/Rune;->COMMON_CONFIG_PACKAGE_NAME_SMART_MANAGER:Ljava/lang/String;
+    sget-object v0, Lcom/samsung/android/settings/Rune;->COMMON_CONFIG_PACKAGE_NAME_SMART_MANAGER:Ljava/lang/String;
+
+    iget-object p0, p0, Lcom/android/settingslib/core/AbstractPreferenceController;->mContext:Landroid/content/Context;
+
+    invoke-static {p0}, Lcom/android/settings/Utils;->isDesktopModeEnabled(Landroid/content/Context;)Z
+
+    move-result p0
 
-    const/4 p0, 0x3
+    if-eqz p0, :cond_0
+
+    const/4 p0, 0x5
+
+    return p0
+
+    :cond_0
+    const/4 p0, 0x0
 
     return p0
 .end method
