From 161575434a3c32c81b32531839458f87f623bc5f Mon Sep 17 00:00:00 2001
From: Salvo Giangreco <giangrecosalvo9@gmail.com>
Date: Tue, 26 Aug 2025 00:06:07 +0200
Subject: [PATCH] Allow custom platform signature

Based off: https://github.com/EverestOS-AOSP/frameworks_base/commit/9d302efb52770dfb85e19c51ad31f781c7844ca3

---
 .../pm/PackageManagerServiceUtils.smali       | 10 +++++++
 .../android/server/pm/ScanPackageUtils.smali  | 50 ++++++++++++++++++
 2 files changed, 60 insertions(+)

diff --git a/smali_classes2/com/android/server/pm/PackageManagerServiceUtils.smali b/smali_classes2/com/android/server/pm/PackageManagerServiceUtils.smali
index 43479f0ed..0cd434035 100644
--- a/smali_classes2/com/android/server/pm/PackageManagerServiceUtils.smali
+++ b/smali_classes2/com/android/server/pm/PackageManagerServiceUtils.smali
@@ -619,6 +619,16 @@
     return p0
 .end method
 
+.method public static compareSignaturesActual([Landroid/content/pm/Signature;[Landroid/content/pm/Signature;)I
+    .locals 0
+
+    invoke-static {p0, p1}, Lcom/android/server/pm/PackageManagerServiceUtils;->compareSignatureArrays([Landroid/content/pm/Signature;[Landroid/content/pm/Signature;)I
+
+    move-result p0
+
+    return p0
+.end method
+
 .method public static copyFile(Ljava/lang/String;Ljava/io/File;Ljava/lang/String;)V
     .locals 2
 
diff --git a/smali_classes2/com/android/server/pm/ScanPackageUtils.smali b/smali_classes2/com/android/server/pm/ScanPackageUtils.smali
index 5f3ff92c3..f825a535e 100644
--- a/smali_classes2/com/android/server/pm/ScanPackageUtils.smali
+++ b/smali_classes2/com/android/server/pm/ScanPackageUtils.smali
@@ -371,6 +371,8 @@
 
     if-eqz p2, :cond_c
 
+    move-object v4, p2
+
     invoke-interface {p2}, Lcom/android/server/pm/pkg/AndroidPackage;->getSigningDetails()Landroid/content/pm/SigningDetails;
 
     move-result-object p1
@@ -383,7 +385,26 @@
 
     move-result p1
 
-    if-nez p1, :cond_c
+    if-nez p1, :cond_unica_custom_signature
+
+    goto :cond_b
+
+    :cond_unica_custom_signature
+    invoke-virtual {p2}, Landroid/content/pm/SigningDetails;->getSignatures()[Landroid/content/pm/Signature;
+
+    move-result-object p1
+
+    invoke-static {p1}, Lcom/android/server/pm/ScanPackageUtils;->signedWithCustomSignature([Landroid/content/pm/Signature;)Z
+
+    move-result p1
+
+    if-eqz p1, :cond_c
+
+    invoke-interface {v4}, Lcom/android/server/pm/pkg/AndroidPackage;->getSigningDetails()Landroid/content/pm/SigningDetails;
+
+    move-result-object p1
+
+    invoke-interface {p0, p1}, Lcom/android/internal/pm/parsing/pkg/ParsedPackage;->setSigningDetails(Landroid/content/pm/SigningDetails;)Lcom/android/internal/pm/parsing/pkg/ParsedPackage;
 
     :cond_b
     move v1, v2
@@ -4871,6 +4892,35 @@
     throw v0
 .end method
 
+.method public static signedWithCustomSignature([Landroid/content/pm/Signature;)Z
+    .locals 2
+
+    new-instance v0, Landroid/content/pm/Signature;
+
+    const-string v1, "CONFIG_CUSTOM_PLATFORM_SIGNATURE"
+
+    invoke-direct {v0, v1}, Landroid/content/pm/Signature;-><init>(Ljava/lang/String;)V
+
+    filled-new-array {v0}, [Landroid/content/pm/Signature;
+
+    move-result-object v0
+
+    invoke-static {v0, p0}, Lcom/android/server/pm/PackageManagerServiceUtils;->compareSignaturesActual([Landroid/content/pm/Signature;[Landroid/content/pm/Signature;)I
+
+    move-result p0
+
+    if-nez p0, :cond_0
+
+    const/4 p0, 0x1
+
+    return p0
+
+    :cond_0
+    const/4 p0, 0x0
+
+    return p0
+.end method
+
 .method public static setInstantAppForUser(Lcom/android/server/pm/PackageManagerServiceInjector;Lcom/android/server/pm/PackageSetting;IZZ)V
     .locals 6
 
-- 
2.51.0

