From: ditternation <ditternation@outlook.com>
Date: Tue, 14 Apr 2026 11:24:52 +0200
Subject: [PATCH] Respect MonsterROM-REBORN target SDK bypass toggle

---
 PackageParser.smali                        | 15 ++++++++++++++-
 parsing/FrameworkParsingPackageUtils.smali | 15 ++++++++++++++-
 2 files changed, 28 insertions(+), 2 deletions(-)

diff --git a/smali/android/content/pm/PackageParser.smali b/smali/android/content/pm/PackageParser.smali
index c88d436..0d7d15d 100644
--- a/smali/android/content/pm/PackageParser.smali
+++ b/smali/android/content/pm/PackageParser.smali
@@ -1302,7 +1302,7 @@
 .end method
 
 .method public static greylist-max-o computeMinSdkVersion(ILjava/lang/String;I[Ljava/lang/String;[Ljava/lang/String;)I
-    .locals 3
+    .locals 4
 
     const/4 v0, -0x1
 
@@ -1312,7 +1312,18 @@
 
     if-nez p1, :cond_1
 
-    if-gt p0, p2, :cond_0
+    if-gt p0, p2, :unica_sdkbypass_min_pkgparser
+
+    return p0
+
+    :unica_sdkbypass_min_pkgparser
+    const-string v3, "persist.sys.unica.sdkbypass"
+
+    invoke-static {v3, v2}, Landroid/os/SemSystemProperties;->getBoolean(Ljava/lang/String;Z)Z
+
+    move-result v3
+
+    if-eqz v3, :cond_0
 
     return p0
 
diff --git a/smali/android/content/pm/parsing/FrameworkParsingPackageUtils.smali b/smali/android/content/pm/parsing/FrameworkParsingPackageUtils.smali
index 279b8bc..be89d90 100644
--- a/smali/android/content/pm/parsing/FrameworkParsingPackageUtils.smali
+++ b/smali/android/content/pm/parsing/FrameworkParsingPackageUtils.smali
@@ -209,5 +209,5 @@
 
 .method public static blacklist computeMinSdkVersion(ILjava/lang/String;I[Ljava/lang/String;Landroid/content/pm/parsing/result/ParseInput;)Landroid/content/pm/parsing/result/ParseResult;
-    .locals 2
+    .locals 3
     .annotation system Ldalvik/annotation/Signature;
         value = {
@@ -241,7 +241,22 @@
 
     if-nez p1, :cond_1
 
-    if-gt p0, p2, :cond_0
+    if-gt p0, p2, :unica_sdkbypass_min_parsing
+
+    goto :goto_0
+
+    :unica_sdkbypass_min_parsing
+    const-string v2, "persist.sys.unica.sdkbypass"
+
+    const/4 p1, 0x0
+
+    invoke-static {v2, p1}, Landroid/os/SemSystemProperties;->getBoolean(Ljava/lang/String;Z)Z
+
+    move-result v2
+
+    if-eqz v2, :cond_0
+
+    :goto_0
 
     invoke-static {p0}, Ljava/lang/Integer;->valueOf(I)Ljava/lang/Integer;
 
