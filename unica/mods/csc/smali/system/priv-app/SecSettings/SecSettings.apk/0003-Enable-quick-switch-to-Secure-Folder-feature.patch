 .../android/settings/usefulfeature/Usefulfeature$1.smali | 9 ---------
 .../usefulfeature/functionkey/FunctionKeyUtils.smali     | 4 +---
 2 files changed, 1 insertion(+), 12 deletions(-)

diff --git a/smali_classes2/com/samsung/android/settings/usefulfeature/Usefulfeature$1.smali b/smali_classes2/com/samsung/android/settings/usefulfeature/Usefulfeature$1.smali
index d032940..bc20c18 100644
