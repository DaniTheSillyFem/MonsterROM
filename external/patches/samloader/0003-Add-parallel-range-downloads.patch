+def downloadfile_parallel(client, filename, out, size, jobs, resume=False):
+    jobs = max(1, min(jobs, size))
+    chunk_size = int(os.environ.get("SAMLOADER_CHUNK_SIZE", str(128 * 1024 * 1024)))
+    chunk_size = max(0x100000, chunk_size)
+    part_dir = out + ".parts"
+    os.makedirs(part_dir, exist_ok=True)
+    if resume and os.path.isfile(out):
+        _seed_parts_from_file(out, part_dir, size, chunk_size)
+
+    part_retries = int(os.environ.get("SAMLOADER_PART_RETRIES", "5"))
+    part_retries = max(1, part_retries)
+
+    tasks = []
+    parts = []
+    initial = 0
+    index = 0
+    for start in range(0, size, chunk_size):
+        end = min(size - 1, start + chunk_size - 1)
+        part_file = os.path.join(part_dir, "{:06d}.part".format(index))
+        expected = end - start + 1
+        existing = os.path.getsize(part_file) if os.path.isfile(part_file) else 0
+        if existing > expected:
+            existing = 0
+        parts.append((part_file, expected))
+        initial += existing
+        if existing < expected:
+            tasks.append((start, end, part_file, existing))
+        index += 1
+
+    lock = threading.Lock()
+    with tqdm(total=size, initial=initial, unit="B", unit_scale=True) as pbar:
+        with ThreadPoolExecutor(max_workers=jobs) as executor:
+            futures = [
+                executor.submit(_download_part, client, filename, start, end, part_file, existing, pbar, lock, part_retries)
+                for start, end, part_file, existing in tasks
+            ]
+            for future in as_completed(futures):
+                future.result()
+
+    with open(out, "wb") as outf:
+        for part_file, expected in parts:
+            if not os.path.isfile(part_file) or os.path.getsize(part_file) != expected:
+                raise Exception("parallel download produced an incomplete part: {}".format(part_file))
+            with open(part_file, "rb") as part:
+                while True:
+                    chunk = part.read(0x100000)
+                    if not chunk:
+                        break
+                    outf.write(chunk)
+            os.remove(part_file)
+    os.rmdir(part_dir)
+
+
+def _seed_parts_from_file(out, part_dir, size, chunk_size):
+    remaining = min(os.path.getsize(out), size)
+    if remaining <= 0:
+        return
+
+    index = 0
+    with open(out, "rb") as inf:
+        while remaining > 0:
+            expected = min(chunk_size, size - (index * chunk_size))
+            if expected <= 0:
+                break
+
+            part_file = os.path.join(part_dir, "{:06d}.part".format(index))
+            existing = os.path.getsize(part_file) if os.path.isfile(part_file) else 0
+            if existing > expected:
+                existing = 0
+
+            skipped = min(existing, remaining)
+            if skipped > 0:
+                inf.seek(skipped, os.SEEK_CUR)
+                remaining -= skipped
+
+            to_copy = min(expected - existing, remaining)
+            if to_copy > 0:
+                with open(part_file, "ab" if existing else "wb") as part:
+                    while to_copy > 0:
+                        chunk = inf.read(min(0x100000, to_copy))
+                        if not chunk:
+                            break
+                        part.write(chunk)
+                        copied = len(chunk)
+                        remaining -= copied
+                        to_copy -= copied
+            index += 1
+
+    os.remove(out)
+
+
+def _download_part(client, filename, start, end, part_file, existing, pbar, lock, retries):
+    expected = end - start + 1
+    attempts = 0
+
+    while True:
+        current = os.path.getsize(part_file) if os.path.isfile(part_file) else 0
+        if current == expected:
+            return
+        if current > expected:
+            raise Exception("parallel download part grew beyond its expected size: {}".format(part_file))
+
+        offset = start + current
+        response = None
+        try:
+            response = client.downloadfile(filename, offset, end)
+            if response.status_code != 206:
+                raise Exception("server ignored ranged download request")
+            with open(part_file, "ab" if current else "wb") as fd:
+                for chunk in response.iter_content(chunk_size=0x100000):
+                    if chunk:
+                        fd.write(chunk)
+                        current += len(chunk)
+                        with lock:
+                            pbar.update(len(chunk))
+            if current == expected:
+                return
+            raise Exception("ranged download ended before part was complete")
+        except Exception:
+            attempts += 1
+            if attempts >= retries:
+                raise
+            time.sleep(min(30, 2 ** (attempts - 1)))
+        finally:
+            if response is not None:
+                response.close()
 
